
{
  "entities": {
    "Delegate": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Delegate",
      "type": "object",
      "description": "Represents a delegate participating in the Model United Nations session.",
      "properties": {
        "id": { "type": "string" },
        "countryName": { "type": "string" },
        "passwordHash": { "type": "string" }
      },
      "required": ["id", "countryName", "passwordHash"]
    },
    "Action": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Action",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "Participation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Participation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "actionId": { "type": "string" },
        "delegateId": { "type": "string" }
      }
    },
    "Resolution": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Resolution",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "Un message privé envoyé par un délégué à la présidence.",
      "properties": {
        "id": { "type": "string" },
        "senderCountry": { "type": "string" },
        "type": { "type": "string", "enum": ["privilege", "general"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "senderCountry", "type", "content", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/delegates/{delegateId}",
        "definition": { "entityName": "Delegate", "schema": { "$ref": "#/backend/entities/Delegate" } }
      },
      {
        "path": "/actions/{actionId}",
        "definition": { "entityName": "Action", "schema": { "$ref": "#/backend/entities/Action" } }
      },
      {
        "path": "/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Messages privés pour la présidence."
        }
      }
    ]
  }
}
