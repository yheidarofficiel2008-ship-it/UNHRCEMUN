
{
  "entities": {
    "Committee": {
      "title": "Committee",
      "type": "object",
      "description": "Un comité spécifique (ex: UNHRC, ECOSOC).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "president_email": { "type": "string" },
        "president_password": { "type": "string" },
        "language": { "type": "string", "enum": ["fr", "en"], "default": "fr" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Delegate": {
      "title": "Delegate",
      "type": "object",
      "description": "Représente un pays délégué au MUN.",
      "properties": {
        "id": { "type": "string" },
        "country_name": { "type": "string" },
        "password": { "type": "string" },
        "is_suspended": { "type": "boolean", "default": false }
      },
      "required": ["country_name", "password"]
    },
    "Action": {
      "title": "Action",
      "type": "object",
      "description": "Une action de débat lancée par la présidence.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["launched", "started", "paused", "completed"] },
        "duration_minutes": { "type": "number" },
        "time_per_delegate": { "type": "string" }
      }
    },
    "Resolution": {
      "title": "Resolution",
      "type": "object",
      "description": "Un projet de résolution soumis par un pays.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "proposing_country": { "type": "string" },
        "spokesperson": { "type": "string" },
        "sponsors": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "is_displayed": { "type": "boolean" }
      }
    },
    "PositionPaper": {
      "title": "Position Paper",
      "type": "object",
      "description": "Un texte de positionnement officiel soumis par un pays.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "proposing_country": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/committees/{committeeId}": { "schema": "Committee", "description": "Données du comité." },
    "/committees/{committeeId}/delegates/{id}": { "schema": "Delegate", "description": "Délégués du comité." },
    "/committees/{committeeId}/actions/{id}": { "schema": "Action", "description": "Actions du comité." },
    "/committees/{committeeId}/resolutions/{id}": { "schema": "Resolution", "description": "Résolutions du comité." },
    "/committees/{committeeId}/positionPapers/{id}": { "schema": "PositionPaper", "description": "Textes de positionnement du comité." },
    "/committees/{committeeId}/messages/{id}": { "schema": "object", "description": "Messages du comité." },
    "/committees/{committeeId}/sessionState/{id}": { "schema": "object", "description": "État de la session." }
  }
}
