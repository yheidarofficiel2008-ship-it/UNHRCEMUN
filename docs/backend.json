
{
  "entities": {
    "Committee": {
      "title": "Committee",
      "type": "object",
      "description": "Un comité spécifique (ex: UNHRC, ECOSOC).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "Delegate": {
      "title": "Delegate",
      "type": "object",
      "description": "Représente un pays délégué au MUN.",
      "properties": {
        "id": { "type": "string" },
        "committeeId": { "type": "string" },
        "country_name": { "type": "string" },
        "password": { "type": "string" },
        "is_suspended": { "type": "boolean", "default": false }
      },
      "required": ["country_name", "password", "committeeId"]
    },
    "Action": {
      "title": "Action",
      "type": "object",
      "description": "Une action de débat lancée par la présidence.",
      "properties": {
        "id": { "type": "string" },
        "committeeId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["launched", "started", "paused", "completed"] },
        "duration_minutes": { "type": "number" },
        "time_per_delegate": { "type": "string" }
      }
    },
    "Resolution": {
      "title": "Resolution",
      "type": "object",
      "description": "Un projet de résolution soumis par un pays.",
      "properties": {
        "id": { "type": "string" },
        "committeeId": { "type": "string" },
        "title": { "type": "string" },
        "proposing_country": { "type": "string" },
        "spokesperson": { "type": "string" },
        "sponsors": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "is_displayed": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/committees/{committeeId}": { "schema": "Committee", "description": "Données de base du comité." },
    "/committees/{committeeId}/delegates/{id}": { "schema": "Delegate", "description": "Délégués par comité." },
    "/committees/{committeeId}/actions/{id}": { "schema": "Action", "description": "Débats par comité." },
    "/committees/{committeeId}/resolutions/{id}": { "schema": "Resolution", "description": "Résolutions par comité." }
  }
}
