
{
  "entities": {
    "Delegate": {
      "title": "Delegate",
      "type": "object",
      "description": "Représente un pays délégué au MUN.",
      "properties": {
        "id": { "type": "string" },
        "country_name": { "type": "string" },
        "password": { "type": "string" },
        "is_suspended": { "type": "boolean", "default": false }
      },
      "required": ["country_name", "password"]
    },
    "Action": {
      "title": "Action",
      "type": "object",
      "description": "Une action de débat lancée par la présidence.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["launched", "started", "paused", "completed"] },
        "duration_minutes": { "type": "number" },
        "time_per_delegate": { "type": "string" }
      }
    },
    "Resolution": {
      "title": "Resolution",
      "type": "object",
      "description": "Un projet de résolution soumis par un pays.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "description": "Le titre de la résolution." },
        "proposing_country": { "type": "string" },
        "spokesperson": { "type": "string", "description": "Le porte-parole de la délégation." },
        "sponsors": { "type": "string", "description": "Liste des pays soutenant la résolution." },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "is_displayed": { "type": "boolean" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "Un message privé pour la présidence.",
      "properties": {
        "id": { "type": "string" },
        "sender_country": { "type": "string" },
        "type": { "type": "string", "enum": ["privilege", "general"] },
        "content": { "type": "string" },
        "is_read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Participation": {
      "title": "Participation",
      "type": "object",
      "description": "Enregistrement d'un pays sur une liste d'orateurs.",
      "properties": {
        "action_id": { "type": "string" },
        "delegate_id": { "type": "string" },
        "country_name": { "type": "string" },
        "status": { "type": "string", "enum": ["participating", "passing"] },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/delegates/{id}": { "schema": "Delegate", "description": "Liste des pays enregistrés." },
    "/actions/{id}": { "schema": "Action", "description": "Actions et débats en cours." },
    "/resolutions/{id}": { "schema": "Resolution", "description": "Projets de résolutions soumis." },
    "/messages/{id}": { "schema": "Message", "description": "Messages privés délégués -> présidence." },
    "/participations/{id}": { "schema": "Participation", "description": "Historique des participations aux débats." },
    "/sessionState/current": { "schema": "object", "description": "Paramètres globaux de la session." }
  }
}
