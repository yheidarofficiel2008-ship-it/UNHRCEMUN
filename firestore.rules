
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isPresident() {
      // Un président est identifié par son document dans la collection roles_president
      return isSignedIn() && exists(/databases/$(database)/documents/roles_president/$(request.auth.uid));
    }

    // --- RÈGLES DES COLLECTIONS ---

    match /delegates/{delegateId} {
      // Lecture permise pour tout le monde (pour permettre la recherche par pays au login)
      allow read: if true;
      // Seul le président gère les délégués
      allow write: if isPresident();
    }

    match /roles_president/{presidentUid} {
      // Un président peut créer son propre rôle lors de l'initialisation
      allow get, create, update: if isSignedIn() && request.auth.uid == presidentUid;
      allow list, delete: if false;
    }

    match /actions/{actionId} {
      // Lecture publique de l'état de la séance
      allow read: if true;
      // Seul le président gère les actions
      allow write: if isPresident();

      match /participations/{participationId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update: if isPresident() || (isSignedIn() && request.auth.uid == resource.data.delegateId);
        allow delete: if isPresident();
      }
    }

    match /resolutions/{resolutionId} {
      // Lecture publique pour voir les statuts
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isPresident() || (isSignedIn() && request.auth.uid == resource.data.delegateId);
      allow delete: if isPresident();
    }

    match /sessionState/current {
      // Lecture publique pour l'overlay de suspension
      allow read: if true;
      allow write: if isPresident();
    }

    // Règle de repli
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isPresident();
    }
  }
}
