rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MODEL UNITED NATIONS (MUN) SESSION SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isPresident() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_president/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /delegates/{delegateId} {
      // Les délégués doivent pouvoir se trouver pour la connexion
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create, update, delete: if isPresident();
    }

    match /roles_president/{presidentUid} {
      allow get: if isOwner(presidentUid);
      // Permettre la création par l'utilisateur lui-même lors de l'inscription (Initialisation)
      allow create: if isOwner(presidentUid);
      allow list, update, delete: if false;
    }

    match /actions/{actionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isPresident();

      match /participations/{participationId} {
        allow get: if isPresident() || (isSignedIn() && request.auth.uid == resource.data.delegateId);
        allow list: if isPresident() || (isSignedIn() && request.query.limit <= 100);
        allow create: if isSignedIn() && request.resource.data.delegateId == request.auth.uid && request.resource.data.actionId == actionId;
        allow update: if isPresident() || (isSignedIn() && request.auth.uid == resource.data.delegateId);
        allow delete: if isPresident();
      }
    }

    match /resolutions/{resolutionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.delegateId == request.auth.uid;
      allow update: if isPresident() || (isSignedIn() && request.auth.uid == resource.data.delegateId);
      allow delete: if isPresident();
    }

    match /sessionState/current {
      allow get: if isSignedIn();
      allow create, update: if isPresident();
      allow list, delete: if false;
    }

    // Règle de repli
    match /{document=**} {
      allow read, write: if isPresident();
    }
  }
}