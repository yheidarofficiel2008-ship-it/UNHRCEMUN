
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isPresident() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_president/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- RÈGLES DES COLLECTIONS ---

    match /delegates/{delegateId} {
      // Les délégués et le président peuvent voir la liste (pour le login et la gestion)
      allow read: if isSignedIn();
      // Seul le président gère les délégués
      allow write: if isPresident();
    }

    match /roles_president/{presidentUid} {
      // Un président peut créer et voir son propre document de rôle
      allow get, create, update: if isOwner(presidentUid);
      allow list, delete: if false;
    }

    match /actions/{actionId} {
      // Tout utilisateur connecté peut voir les actions
      allow read: if isSignedIn();
      // Seul le président peut gérer les actions
      allow write: if isPresident();

      match /participations/{participationId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.delegateId == request.auth.uid;
        allow update: if isPresident() || (isSignedIn() && request.auth.uid == resource.data.delegateId);
        allow delete: if isPresident();
      }
    }

    match /resolutions/{resolutionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.delegateId == request.auth.uid;
      allow update: if isPresident() || (isSignedIn() && request.auth.uid == resource.data.delegateId);
      allow delete: if isPresident();
    }

    match /sessionState/current {
      allow read: if isSignedIn();
      allow write: if isPresident();
    }

    // Règle de repli
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if isPresident();
    }
  }
}
