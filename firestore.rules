rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Règle simplifiée au maximum pour le développement et la simulation
    // Permet à tout utilisateur connecté (Président ou Délégué anonyme) de lire et écrire
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}